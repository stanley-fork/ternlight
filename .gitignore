# ── JS ──────────────────────────────────────────────────────────────────────
node_modules/
.pnpm-store/
*.log
.npmrc
dist/
build/
.next/
.cache/
coverage/

# ── Rust ────────────────────────────────────────────────────────────────────
target/
**/*.rs.bk
Cargo.lock          # workspace lockfile — committed for binaries, ignored for libraries.
                    # Once we ship a binary tool from this repo, remove this line.
engine/pkg/         # wasm-pack output — regenerated per build, copied into packages/

# ── Python ──────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
.python-version
*.egg-info/
.pytest_cache/

# ── Model artifacts (kept out of git, attached to GitHub Releases) ──────────
*.bin
*.pt
*.safetensors
training/distill/runs/
training/distill/cache/
training/distill/wandb/
training/pack/out/          # packed .bin output — attached to GitHub Releases, not committed
engine/assets/model.bin     # generated by training/pack — see models/README.md

# Reference test data caches — large, regenerated by prepare scripts
eval/regression/test_data/*.json
!eval/regression/test_data/.gitkeep

# ── OS / editor ─────────────────────────────────────────────────────────────
.DS_Store
.idea/
.vscode/
.obsidian/
*.swp
*.swo
.env
.env.local

# ── Deploy tooling ──────────────────────────────────────────────────────────
.vercel/            # Vercel CLI's local project link — contains your account/project IDs

# ── Claude Code (local overrides) ───────────────────────────────────────────
.claude/settings.local.json
.claude/settings.json
.docs/